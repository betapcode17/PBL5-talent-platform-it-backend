{"file":"E:\\HOCKI6\\PBL5\\backend\\src\\prisma.service.ts","mappings":";;;;;;;;;;AAAA,OAAO,EAAE,UAAU,EAAE,MAAM,gBAAgB,CAAC;AAC5C,OAAO,EAAE,aAAa,EAAE,MAAM,gBAAgB,CAAC;AAC/C,OAAO,EAAE,YAAY,EAAE,MAAM,8BAA8B,CAAC;AAC5D,OAAO,EAAE,QAAQ,EAAE,MAAM,oBAAoB,CAAC;AAGvC,IAAM,aAAa,GAAnB,MAAM,aAAc,SAAQ,YAAY;IACzB;IAApB,YAAoB,aAA4B;QAC9C,kJAAkJ;QAClJ,MAAM,KAAK,GAAG,aAAa,CAAC,GAAG,CAAS,cAAc,CAAC,CAAC;QAExD,IAAI,CAAC,KAAK,EAAE,CAAC;YACX,MAAM,IAAI,KAAK,CAAC,6BAA6B,CAAC,CAAC;QACjD,CAAC;QAED,MAAM,OAAO,GAAG,IAAI,QAAQ,CAAC;YAC3B,mEAAmE;YACnE,gBAAgB,EAAE,KAAK;SACxB,CAAC,CAAC;QAEH,KAAK,CAAC,EAAE,OAAO,EAAE,CAAC,CAAC;QAbD,kBAAa,GAAb,aAAa,CAAe;IAchD,CAAC;CACF,CAAA;AAhBY,aAAa;IADzB,UAAU,EAAE;yDAEwB,aAAa,oBAAb,aAAa;GADrC,aAAa,CAgBzB","names":[],"sources":["E:\\HOCKI6\\PBL5\\backend\\src\\prisma.service.ts"],"sourcesContent":["import { Injectable } from '@nestjs/common';\nimport { ConfigService } from '@nestjs/config';\nimport { PrismaClient } from './generated/prisma/client.js';\nimport { PrismaPg } from '@prisma/adapter-pg';\n\n@Injectable()\nexport class PrismaService extends PrismaClient {\n  constructor(private configService: ConfigService) {\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment, @typescript-eslint/no-unsafe-call, @typescript-eslint/no-unsafe-member-access\n    const dbUrl = configService.get<string>('DATABASE_URL');\n\n    if (!dbUrl) {\n      throw new Error('DATABASE_URL is not defined');\n    }\n\n    const adapter = new PrismaPg({\n      // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment\n      connectionString: dbUrl,\n    });\n\n    super({ adapter });\n  }\n}\n"],"version":3}