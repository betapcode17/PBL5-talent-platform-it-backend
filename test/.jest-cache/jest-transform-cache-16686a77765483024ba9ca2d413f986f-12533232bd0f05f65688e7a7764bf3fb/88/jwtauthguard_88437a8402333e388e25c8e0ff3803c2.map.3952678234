{"file":"E:\\HOCKI6\\PBL5\\backend\\src\\jwt\\jwt-auth.guard.ts","mappings":";;;;;;;;;;AAAA,OAAO,EAGL,UAAU,EACV,qBAAqB,GACtB,MAAM,gBAAgB,CAAC;AACxB,OAAO,EAAE,SAAS,EAAE,MAAM,kBAAkB,CAAC;AAC7C,OAAO,EAAE,aAAa,EAAE,MAAM,sBAAsB,CAAC;AACrD,OAAO,EAAE,UAAU,EAAE,MAAM,cAAc,CAAC;AAGnC,IAAM,YAAY,GAAlB,MAAM,YAAa,SAAQ,SAAS,CAAC,KAAK,CAAC;IAC5B;IAApB,YAAoB,MAAqB;QACvC,KAAK,EAAE,CAAC;QADU,WAAM,GAAN,MAAM,CAAe;IAEzC,CAAC;IAED,WAAW,CAAC,OAAY;QACtB,kJAAkJ;QAClJ,MAAM,OAAO,GAAG,OAAO,CAAC,YAAY,EAAE,CAAC,UAAU,EAAE,CAAC;QAEpD,MAAM,KAAK,GAAG,UAAU,CAAC,2BAA2B,EAAE,CAAC,OAAO,CAAC,CAAC;QAEhE,IAAI,CAAC,KAAK,EAAE,CAAC;YACX,MAAM,IAAI,qBAAqB,CAAC,iBAAiB,CAAC,CAAC;QACrD,CAAC;QAED,4DAA4D;QAC5D,mEAAmE;QACnE,iEAAiE;QACjE,OAAO,KAAK,CAAC,WAAW,CAAC,OAAO,CAAY,CAAC;IAC/C,CAAC;CACF,CAAA;AApBY,YAAY;IADxB,UAAU,EAAE;yDAEiB,aAAa,oBAAb,aAAa;GAD9B,YAAY,CAoBxB;;AAGM,IAAM,iBAAiB,GAAvB,MAAM,iBAAiB;IACR;IAApB,YAAoB,MAAqB;QAArB,WAAM,GAAN,MAAM,CAAe;IAAG,CAAC;IAE7C,KAAK,CAAC,WAAW,CAAC,GAAqB;QACrC,mEAAmE;QACnE,MAAM,GAAG,GAAG,GAAG,CAAC,YAAY,EAAE,CAAC,UAAU,EAAE,CAAC;QAC5C,+GAA+G;QAC/G,MAAM,IAAI,GAAG,GAAG,CAAC,IAAI,CAAC;QAEtB,sEAAsE;QACtE,IAAI,IAAI,CAAC,IAAI,KAAK,UAAU;YAAE,OAAO,IAAI,CAAC;QAE1C,sEAAsE;QACtE,MAAM,MAAM,GAAG,MAAM,CAAC,GAAG,CAAC,IAAI,CAAC,MAAM,IAAI,GAAG,CAAC,MAAM,CAAC,MAAM,CAAC,CAAC;QAE5D,MAAM,IAAI,GAAG,MAAM,IAAI,CAAC,MAAM,CAAC,IAAI,CAAC,UAAU,CAAC;YAC7C,KAAK,EAAE,EAAE,OAAO,EAAE,MAAM,EAAE;SAC3B,CAAC,CAAC;QAEH,IAAI,CAAC,IAAI;YAAE,OAAO,KAAK,CAAC;QAExB,MAAM,QAAQ,GAAG,MAAM,IAAI,CAAC,MAAM,CAAC,QAAQ,CAAC,UAAU,CAAC;YACrD,+GAA+G;YAC/G,KAAK,EAAE,EAAE,WAAW,EAAE,IAAI,CAAC,MAAM,EAAE;SACpC,CAAC,CAAC;QAEH,OAAO,QAAQ,EAAE,UAAU,KAAK,IAAI,CAAC,UAAU,CAAC;IAClD,CAAC;CACF,CAAA;AA5BY,iBAAiB;IAD7B,UAAU,EAAE;yDAEiB,aAAa,oBAAb,aAAa;GAD9B,iBAAiB,CA4B7B","names":[],"sources":["E:\\HOCKI6\\PBL5\\backend\\src\\jwt\\jwt-auth.guard.ts"],"sourcesContent":["import {\n  CanActivate,\n  ExecutionContext,\n  Injectable,\n  UnauthorizedException,\n} from '@nestjs/common';\nimport { AuthGuard } from '@nestjs/passport';\nimport { PrismaService } from '../prisma.service.js';\nimport { ExtractJwt } from 'passport-jwt';\n\n@Injectable()\nexport class JwtAuthGuard extends AuthGuard('jwt') {\n  constructor(private prisma: PrismaService) {\n    super();\n  }\n\n  canActivate(context: any): boolean {\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment, @typescript-eslint/no-unsafe-call, @typescript-eslint/no-unsafe-member-access\n    const request = context.switchToHttp().getRequest();\n\n    const token = ExtractJwt.fromAuthHeaderAsBearerToken()(request);\n\n    if (!token) {\n      throw new UnauthorizedException('Token not found');\n    }\n\n    // Bang Token hien tai chi luu refresh token va reset token.\n    // Access token khong duoc luu DB, vi vay guard chi can verify JWT.\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-argument\n    return super.canActivate(context) as boolean;\n  }\n}\n\n@Injectable()\nexport class EmployeeChatGuard implements CanActivate {\n  constructor(private prisma: PrismaService) {}\n\n  async canActivate(ctx: ExecutionContext) {\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment\n    const req = ctx.switchToHttp().getRequest();\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment, @typescript-eslint/no-unsafe-member-access\n    const user = req.user;\n\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-member-access\n    if (user.role !== 'EMPLOYEE') return true;\n\n    // eslint-disable-next-line @typescript-eslint/no-unsafe-member-access\n    const chatId = Number(req.body.chatId || req.params.chatId);\n\n    const chat = await this.prisma.chat.findUnique({\n      where: { chat_id: chatId },\n    });\n\n    if (!chat) return false;\n\n    const employee = await this.prisma.employee.findUnique({\n      // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment, @typescript-eslint/no-unsafe-member-access\n      where: { employee_id: user.userId },\n    });\n\n    return employee?.company_id === chat.company_id;\n  }\n}\n"],"version":3}