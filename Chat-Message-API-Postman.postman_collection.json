            "url": {
              "raw": "http://localhost:3000/message",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"]
            }
          }
        },
        {
          "name": "Send Message (Employee 1 Reply)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken1}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"chatId\": {{chat1Id}}, \"content\": \"Great! Your profile looks impressive. Can you share your experience?\"}"
            },
            "url": {
              "raw": "http://localhost:3000/message",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"]
            }
          }
        },
        {
          "name": "Send Message (Employee 2 Reply)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken2}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"chatId\": {{chat2Id}}, \"content\": \"Perfect! Let's schedule an interview next week.\"}"
            },
            "url": {
              "raw": "http://localhost:3000/message",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"]
