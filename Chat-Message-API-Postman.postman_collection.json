{
  "info": {
    "name": "Chat & Message API Tests",
    "description": "Complete API test collection for Chat and Message modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{seekerToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login as Seeker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('seekerToken', response.access_token);",
                  "    pm.environment.set('seekerId', response.user.seeker_id);",
                  "    pm.environment.set('seekerUserId', response.user.user_id);",
                  "    console.log('✅ Seeker logged in successfully');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"seeker@example.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Employee (TechCorp)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('employeeToken1', response.access_token);",
                  "    pm.environment.set('employeeUserId1', response.user.user_id);",
                  "    pm.environment.set('companyId1', response.user.company_id || 1);",
                  "    console.log('✅ Employee 1 logged in successfully');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"hr@techcorp.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Employee (StartupVN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('employeeToken2', response.access_token);",
                  "    pm.environment.set('employeeUserId2', response.user.user_id);",
                  "    pm.environment.set('companyId2', response.user.company_id || 2);",
                  "    console.log('✅ Employee 2 logged in successfully');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"hr2@startupvn.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat API - Seeker",
      "item": [
        {
          "name": "Create Chat (Seeker → TechCorp)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('chat1Id', response.chat_id);",
                  "    console.log('✅ Chat created:', response.chat_id);",
                  "} else {",
                  "    console.log('Response:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"company_id\": 1}"
            },
            "url": {
              "raw": "http://localhost:3000/chat",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["chat"]
            }
          }
        },
        {
          "name": "Create Chat (Seeker → StartupVN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('chat2Id', response.chat_id);",
                  "    console.log('✅ Chat created:', response.chat_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"company_id\": 2}"
            },
            "url": {
              "raw": "http://localhost:3000/chat",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["chat"]
            }
          }
        },
        {
          "name": "Get My Chats (Seeker)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/chat/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["chat", "me"]
            }
          }
        },
        {
          "name": "Get Chat Detail (Chat 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('Chat Detail:', JSON.stringify(pm.response.json(), null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/chat/{{chat1Id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["chat", "{{chat1Id}}"]
            }
          }
        },
        {
          "name": "Get Chat Detail (Chat 2)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/chat/{{chat2Id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["chat", "{{chat2Id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Message API - Send",
      "item": [
        {
          "name": "Send Message (Seeker to Chat 1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"chatId\": {{chat1Id}}, \"content\": \"Hello TechCorp! I'm interested in the Backend Developer position.\"}"
            },
            "url": {
              "raw": "http://localhost:3000/message",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"]
            }
          }
        },
        {
          "name": "Send Message (Seeker to Chat 2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
