        }
      ]
    },
    {
      "name": "Message API - Retrieve",
      "item": [
        {
          "name": "Get Messages from Chat 1",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/message?chatId={{chat1Id}}&limit=50&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"],
              "query": [
                {
                  "key": "chatId",
                  "value": "{{chat1Id}}"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Messages from Chat 2",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/message?chatId={{chat2Id}}&limit=50&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"],
              "query": [
                {
                  "key": "chatId",
                  "value": "{{chat2Id}}"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Messages with Pagination (limit=10)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/message?chatId={{chat1Id}}&limit=10&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["message"],
              "query": [
                {
                  "key": "chatId",
                  "value": "{{chat1Id}}"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
