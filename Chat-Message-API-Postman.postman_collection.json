              },
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"chatId\": {{chat2Id}}, \"content\": \"Hi StartupVN! Looking forward to discussing the Python role.\"}"
